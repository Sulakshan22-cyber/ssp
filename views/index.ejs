<!DOCTYPE html>
<html>
<head>
<title>Student Registration</title>
<style>
  body {
    font-family: Arial, sans-serif;
    margin: 0;
    padding: 0;
    background: linear-gradient(135deg, #7c99f2 0%, #a0e7f5 100%);
    color: #2d3a56;
  }

  .page-wrapper {
    max-width: 1000px;
    margin: 0 auto;
    padding: 30px 20px 60px;
  }

  .hero {
    text-align: center;
    margin-bottom: 30px;
  }

  h1 {
    margin: 0;
    font-size: 2.8rem;
    letter-spacing: 1px;
  }

  .subtitle {
    margin: 8px auto 0;
    color: #3b4a6b;
    font-size: 1rem;
  }

  .card {
    background: #ffffffcc;
    border-radius: 16px;
    box-shadow: 0 18px 40px rgba(45, 58, 86, 0.18);
    padding: 28px;
    margin-bottom: 32px;
  }

  form {
    display: grid;
    gap: 18px;
  }

  .field-group {
    display: grid;
    grid-template-columns: 150px 1fr;
    align-items: center;
    gap: 12px;
  }

  .field-group label {
    font-weight: 600;
  }

  input[type="text"],
  input[type="email"],
  input[type="tel"] {
    width: 100%;
    padding: 12px 14px;
    border-radius: 10px;
    border: 1px solid #c8d2e4;
    background: #f7f9ff;
    transition: border-color 0.2s ease;
  }

  input:focus {
    outline: none;
    border-color: #6c8af4;
    background: #ffffff;
  }

  .button-row {
    text-align: right;
  }

  button {
    background: #4a73ff;
    color: white;
    border: none;
    padding: 12px 24px;
    font-size: 1rem;
    border-radius: 10px;
    cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  button:hover {
    transform: translateY(-1px);
    box-shadow: 0 10px 24px rgba(74, 115, 255, 0.25);
  }

  .section-title {
    margin: 0 0 18px;
    font-size: 1.6rem;
    letter-spacing: 0.5px;
  }

  .table-card {
    background: #ffffffcc;
    border-radius: 16px;
    padding: 24px;
    box-shadow: 0 18px 40px rgba(45, 58, 86, 0.14);
  }

  table {
    width: 100%;
    border-collapse: collapse;
    min-width: 620px;
  }

  th, td {
    padding: 14px 16px;
    text-align: left;
  }

  thead {
    background: #4a73ff;
    color: white;
  }

  tbody tr:nth-child(even) {
    background: #f3f6ff;
  }

  tbody tr:hover {
    background: #e8eefc;
  }

  td {
    color: #2f3b56;
  }

  .empty-message {
    margin: 0;
    color: #52618d;
    font-style: italic;
  }

  @media (max-width: 720px) {
    .field-group {
      grid-template-columns: 1fr;
    }

    .button-row {
      text-align: center;
    }
  }
</style>
</head>
<body>
<div class="page-wrapper">
  <header class="hero">
    <h1>Student Registration</h1>
    <p class="subtitle">Add student details clearly and keep your class roster organized.</p>
  </header>

  <section class="card">
    <h2 class="section-title">Registration Form</h2>
    <form action="/submit" method="POST">
      <div class="field-group">
        <label for="studentName">Name:</label>
        <input type="text" id="studentName" name="studentName" required>
      </div>

      <div class="field-group">
        <label for="studentEmail">Email:</label>
        <input type="email" id="studentEmail" name="studentEmail" required>
      </div>

      <div class="field-group">
        <label for="program">Program:</label>
        <input type="text" id="program" name="program" required>
      </div>

      <div class="field-group">
        <label for="phone">Phone Number:</label>
        <input type="tel" id="phone" name="phone" required>
      </div>

      <div class="field-group">
        <label for="icNumber">IC Number:</label>
        <input type="text" id="icNumber" name="icNumber" required>
      </div>

      <div class="button-row">
        <button type="submit">Submit Registration</button>
      </div>
    </form>
  </section>

  <section class="table-card">
    <h2 class="section-title">Registered Students</h2>
    <% if (students.length === 0) { %>
      <p class="empty-message">No students have been registered yet.</p>
    <% } else { %>
      <table>
        <thead>
          <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Email</th>
            <th>Program</th>
            <th>Phone</th>
            <th>IC Number</th>
          </tr>
        </thead>
        <tbody>
          <% students.forEach(student => { %>
            <tr>
              <td><%= student.id %></td>
              <td><%= student.name %></td>
              <td><%= student.email %></td>
              <td><%= student.program || '' %></td>
              <td><%= student.phone || '' %></td>
              <td><%= student.icNumber || '' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </section>
</div>
</body>
</html>