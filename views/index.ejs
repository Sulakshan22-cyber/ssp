<!DOCTYPE html> 
<html> 
<head> 
  <meta charset="UTF-8"> 
  <meta name="viewport" content="width=device-width, initial-scale=1.0"> 
  <title>Student Registration</title> 
  <link rel="stylesheet" href="/styles.css"> 
</head> 
<body> 
  <main class="page-shell"> 
    <header class="site-header"> 
      <div> 
        <p class="eyebrow">Student Portal</p> 
        <h1>Register for Classes</h1> 
        <p class="hero-copy">Add your details below and keep track of registered students in one clean dashboard.</p> 
      </div> 
      <div class="header-badge">Fast registration</div> 
    </header> 

    <div class="grid-layout"> 
      <section class="card"> 
        <div class="panel-heading"> 
          <h2>New Student</h2> 
          <p>Provide your current IC number, phone, program, email, and full name.</p> 
        </div> 
        <form action="/submit" method="POST" class="form-grid"> 
          <div class="field-group"> 
            <span>Name</span> 
            <input type="text" name="studentName" placeholder="Full name" required> 
          </div> 
          <div class="field-group"> 
            <span>Email</span> 
            <input type="email" name="studentEmail" placeholder="example@mail.com" required> 
          </div> 
          <div class="field-group"> 
            <span>IC Number</span> 
            <input type="text" name="studentIC" placeholder="123456-78-9012" required> 
          </div> 
          <div class="field-group"> 
            <span>Phone Number</span> 
            <input type="tel" name="studentPhone" placeholder="012-3456789" required> 
          </div> 
          <div class="field-group"> 
            <span>Program</span> 
            <input type="text" name="studentProgram" placeholder="Computer Science" required> 
          </div> 
          <div class="form-actions"> 
            <button type="submit" class="btn btn-primary">Submit</button> 
          </div> 
        </form> 
      </section> 

      <section class="card"> 
        <div class="panel-heading"> 
          <h2>Registered Students</h2> 
          <p>Review the current list of registered students and edit or remove entries as needed.</p> 
        </div> 
        <div class="form-grid"> 
          <div class="table-container"> 
            <table class="student-table"> 
              <thead> 
                <tr> 
                  <th>ID</th> 
                  <th>Name</th> 
                  <th>Email</th> 
                  <th>Program</th> 
                  <th>Phone</th> 
                  <th>IC Number</th> 
                  <th>Actions</th> 
                </tr> 
              </thead> 
              <tbody> 
                <% students.forEach(student => { %> 
                <tr> 
                  <td><%= student.id %></td> 
                  <td><%= student.name %></td> 
                  <td><%= student.email %></td> 
                  <td><%= student.program %></td> 
                  <td><%= student.phone %></td> 
                  <td><%= student.icNumber %></td> 
                  <td class="actions-cell"> 
                    <a href="/edit/<%= student.id %>" class="action-link">Edit</a> 
                    <form action="/delete/<%= student.id %>" method="POST" class="inline-form" onsubmit="return confirm('Are you sure you want to delete this student?');"> 
                      <button type="submit" class="btn btn-secondary">Delete</button> 
                    </form> 
                  </td> 
                </tr> 
                <% }) %> 
              </tbody> 
            </table> 
          </div> 
        </div> 
      </section> 
    </div> 
  </main> 
</body> 
</html>